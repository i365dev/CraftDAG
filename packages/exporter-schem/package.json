{
  "name": "@i365dev/craftdag-exporter-schem",
  "version": "0.1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/i365dev/CraftDAG.git",
    "directory": "packages/exporter-schem"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
